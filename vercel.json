{
  "version": 2,
  "public": true,
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/public",
  "routes": [
    {
      "src": "/bundle\\.(\\d+)\\.js",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/styles\\.css",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
