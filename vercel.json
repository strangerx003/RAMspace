{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/public",
  "framework": "react",
  "routes": [
    {
      "src": "/bundle\\.[0-9]+\\.js",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/styles\\.css",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "^/(?!.*\\.).*$",
      "dest": "/index.html"
    }
  ]
}
